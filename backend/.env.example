# SwanyThree Backend Environment Variables

# Server
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/swanythree

# Redis
REDIS_URL=redis://localhost:6379

# SwanyThree Vault Pro (32-byte hex key for AES-256-GCM)
VAULT_MASTER_KEY=

# Stripe
STRIPE_SECRET_KEY=

# OpenRouter (AI)
OPENROUTER_API_KEY=

# LLMLingua
LLMLINGUA_ENDPOINT=http://localhost:8000

# Google Translate
GOOGLE_API_KEY=

# Worker
BACKEND_URL=http://localhost:5000
REDIS_HOST=localhost
REDIS_PORT=6379
