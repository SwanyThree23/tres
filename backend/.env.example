# SwanyThree Backend Environment Variables

# Server
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/swanythree

# Redis
REDIS_URL=redis://localhost:6379

# SwanyThree Vault Pro (32-byte hex key for AES-256-GCM)
# IMPORTANT: In production, use a dedicated KMS (AWS KMS, GCP KMS) instead of env vars.
VAULT_MASTER_KEY=

# Stripe (Connect for payments + Identity for creator verification)
STRIPE_SECRET_KEY=

# OpenRouter (AI)
OPENROUTER_API_KEY=

# LLMLingua
LLMLINGUA_ENDPOINT=http://localhost:8000

# Google Translate
GOOGLE_API_KEY=

# Worker
BACKEND_URL=http://localhost:5000
REDIS_HOST=localhost
REDIS_PORT=6379

# Content Safety (NCMEC CyberTipline integration)
NCMEC_REPORT_URL=https://report.cybertip.org/api
NCMEC_API_KEY=

# AI Watermark signing secret (defaults to VAULT_MASTER_KEY if unset)
WATERMARK_SECRET=
