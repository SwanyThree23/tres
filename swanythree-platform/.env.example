# ══════════════════════════════════════════════════════════════════════
# SwanyThree Platform — Environment Configuration
# Copy this file to .env and fill in the required values
# ══════════════════════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────────────────────
ENV=development
API_PORT=8000
FRONTEND_PORT=3000

# ── Security (REQUIRED — Generate with: openssl rand -hex 32) ───────
SECRET_KEY=CHANGE-ME-generate-with-openssl-rand-hex-32
VAULT_MASTER_KEY=CHANGE-ME-generate-with-openssl-rand-hex-32

# ── Database ─────────────────────────────────────────────────────────
DB_NAME=swanythree
DB_USER=st3user
DB_PASSWORD=CHANGE-ME-generate-with-openssl-rand-hex-16
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://st3user:CHANGE-ME@postgres:5432/swanythree

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/1

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80

# ── Stripe (Payment Processing) ─────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_CHANGE-ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE-ME
PLATFORM_FEE_PERCENT=0.10

# ── AI Services ──────────────────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
WHISPER_URL=http://whisper:8001
DEFAULT_LLM_MODEL=llama3.2:3b
OPENROUTER_API_KEY=sk-or-CHANGE-ME
LLMLINGUA_ENDPOINT=http://llmlingua:8100

# ── Streaming ────────────────────────────────────────────────────────
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
RTMP_URL=rtmp://rtmp:1935/live

# ── Cloudflare R2 (Object Storage) ──────────────────────────────────
CLOUDFLARE_R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_ACCESS_KEY=CHANGE-ME
CLOUDFLARE_R2_SECRET_KEY=CHANGE-ME
CLOUDFLARE_R2_BUCKET=swanythree

# ── Email (SMTP) ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE-ME@gmail.com
SMTP_PASSWORD=CHANGE-ME

# ── Gamification ─────────────────────────────────────────────────────
XP_STREAK_7=1.5
XP_STREAK_14=2.0
XP_STREAK_30=2.5
XP_STREAK_60=3.0

# ── MCP Integration ─────────────────────────────────────────────────
MCP_API_TOKEN=CHANGE-ME
