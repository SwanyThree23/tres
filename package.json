{
    "name": "swanythree-platform",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "install:frontend": "npm install --prefix frontend",
        "install:backend": "pip install -r backend/requirements.txt",
        "backend:dev": "set PYTHONPATH=backend && python -m uvicorn main:app --reload --port 8000",
        "frontend:dev": "npm run dev --prefix frontend",
        "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
        "build": "npm run build --prefix frontend",
        "preview": "npm run preview --prefix frontend"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}