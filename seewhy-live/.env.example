# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-32-byte-hex-secret

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=your-strong-db-password
DATABASE_URL=postgresql+asyncpg://seewhy:your-strong-db-password@postgres:5432/seewhy

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── AI (Claude) ───────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Cloudflare R2 (VOD storage) ───────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=seewhy-recordings
R2_PUBLIC_URL=
